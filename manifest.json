{
    "manifest_version": 3,
    "name": "Tab Auto-Grouper",
    "version": "1.0",
    "description": "Automatically groups tabs by domain.",
    "permissions": ["tabs", "tabGroups", "storage"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_title": "Tab Auto-Grouper"
    },
    "icons": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }